# BBH environment variables — copy to .env.local and fill values

# Supabase (local: get values from `supabase status` after `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Inngest (local dev: leave blank, uses local signing)
# INNGEST_SIGNING_KEY=
# INNGEST_EVENT_KEY=
INNGEST_DEV=1

# LLMs (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Live external APIs
TAVILY_API_KEY=tvly-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_DEMO_CHANNEL=#bbh-demo

# Peec — accessed via committed snapshot file (no API key needed)
# Data refresh manually via Claude Code MCP session
# See decisions/2026-04-25-mcp-only-peec-attio-demo.md
PEEC_SNAPSHOT_PATH=./data/peec-snapshot.json

# Demo brand
DEMO_BRAND_ID=00000000-0000-0000-0000-00000000a771
DEMO_BRAND_SLUG=attio

# Deferred (post-hackathon, see decisions/2026-04-25-hackathon-scope-cut.md)
# FIRECRAWL_API_KEY=fc-...
# RESEND_API_KEY=re_...
# TELLI_API_KEY=
# TELLI_WEBHOOK_SECRET=
# ELEVENLABS_API_KEY=
